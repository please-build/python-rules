_freebsd_ports_hashes = {
    "py310-sqlite3-3.10.20_10": "d32604fc49e7841185a9a5df86b8cbac1c660d8a2bbd78030d8ca5f6e799970c",
    "py311-sqlite3-3.11.15_10": "5a884da810a0771cc3f4a151785302ac20fbe4566ccde129af24d51a196f9bca",
